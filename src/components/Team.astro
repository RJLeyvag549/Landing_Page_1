---
import defaultAvatar from '../assets/default_avatar.png';

const team = [
	{
		role: "Estudiante",
		name: "Roberto Javier Leyva Guerrero",
		details: [
			{ label: "Carrera", value: "Ingeniería En Ejecución En Computación E Informática" },
			{ label: "Depto", value: "Sistemas de Información" },
			{ label: "E-mail", value: "roberto.leyva2301@alumnos.ubiobio.cl" },
			{ label: "Dirección", value: "Emilio Rioseco 336, Concepción" },
			{ label: "Teléfono", value: "+56977905715" }
		]
	},
	{
		role: "Profesor Guía",
		name: "Luis Cabrera Crot",
		details: [
			{ label: "E-mail", value: "lcabrera@ubiobio.cl" }
		]
	},
	{
		role: "Co-Guía (Asesor)",
		name: "Alvaro Sebastian Alarcon Cuevas",
		details: [
			{ label: "E-mail", value: "asalarcon@ubiobio.cl" },
			{ label: "Rubro", value: "Director de Escuela Ing. Civil en Automatización" }
		]
	}
];
---

<section id="team" class="team">
	<div class="section-header">
		<h2 class="section-title typing-title">Identificación del <span class="gradient-text">Proyecto</span></h2>
		<p class="section-subtitle">Estudiantes y equipo de supervisión académica.</p>
	</div>

	<div class="team-grid">
		{team.map((member) => (
			<div class="member-card glass">
				<div class="member-image">
					<img src={defaultAvatar.src} alt={member.name} />
				</div>
				<div class="member-info">
					<span class="member-role">{member.role}</span>
					<h3 class="member-name">{member.name}</h3>
					<div class="member-details">
						{member.details.map((detail) => (
							<div class="detail-item">
								<span class="detail-label">{detail.label}:</span>
								<span class="detail-value">{detail.value}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.team {
		text-align: center;
	}

	.section-header {
		margin-bottom: 4rem;
	}

	.section-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: white;
	}

	.section-subtitle {
		font-size: 1.1rem;
		color: var(--text-secondary);
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.team-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.member-card {
		padding: 2.5rem;
		border-radius: 24px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		transition: transform 0.3s, background 0.3s;
	}

	.member-card:hover {
		transform: translateY(-5px);
		background: rgba(255, 255, 255, 0.05);
	}

	.member-image {
		width: 100px;
		height: 100px;
		border-radius: 50%;
		overflow: hidden;
		margin-bottom: 1.5rem;
		border: 2px solid var(--accent-cyan);
		box-shadow: 0 0 15px rgba(0, 242, 254, 0.2);
	}

	.member-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.member-role {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		color: var(--accent-cyan);
		letter-spacing: 0.1em;
		margin-bottom: 0.5rem;
		display: block;
	}

	.member-name {
		font-size: 1.5rem;
		color: white;
		margin-bottom: 1.5rem;
		font-family: 'Plus Jakarta Sans', sans-serif;
	}

	.member-details {
		text-align: left;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.detail-item {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.detail-label {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--text-secondary);
		text-transform: uppercase;
	}

	.detail-value {
		font-size: 0.95rem;
		color: white;
		word-break: break-all;
	}

	/* Global gradient-text is used from Layout.astro */

	@media (max-width: 768px) {
		.section-title {
			font-size: 2.25rem;
		}
		.team-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
