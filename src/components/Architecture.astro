---
const modules = [
	{
		title: "1. Simulación de Fase (Zernike)",
		subtitle: "Modelado Matemático de Aberraciones",
		description:
			"Motor central que utiliza la base ortogonal de polinomios de Zernike para descomponer frentes de onda complejos. Permite la síntesis controlada de aberraciones ópticas como coma, astigmatismo y trefoil, fundamentales para representar las distorsiones del ELT.",
		details: [
			"Generación de mapas de fase de alta resolución.",
			"Simulación de turbulencia atmosférica residual.",
		],
		image: `${import.meta.env.BASE_URL}/images/software/zernike.png`,
		color: "var(--accent-blue)",
	},
	{
		title: "2. Generador de Dataset Visual",
		subtitle: "Propagación Óptica y Síntesis de Imágenes",
		description:
			"Transforma las matrices de fase puras en representaciones visuales realistas mediante propagación de Fraunhofer (FFT). Este módulo es responsable de crear el puente entre la teoría matemática y la observación digital.",
		details: [
			"Cálculo de PSF (Point Spread Function).",
			"Simulación de submuestreo de detectores CMOS/CCD.",
		],
		image: `${import.meta.env.BASE_URL}/images/software/generator.png`,
		color: "var(--accent-cyan)",
	},
	{
		title: "3. CNN de Reconstrucción",
		subtitle: "Deep Learning para Inferencia de Fase",
		description:
			"Red Neuronal Convolucional diseñada específicamente para la regresión de coeficientes ópticos. Actúa como el cerebro del sistema, analizando patrones de difracción para reconstruir el frente de onda original en tiempo real.",
		details: [
			"Arquitectura optimizada para regresión continua.",
			"Entrenamiento con datasets sintéticos masivos.",
		],
		image: `${import.meta.env.BASE_URL}/images/software/cnn.png`,
		color: "#4d7cff",
	},
];
---

<section id="architecture" class="architecture-section">
	<div class="container">
		<div class="header">
			<h2 class="section-title typing-title">
				Estructura del <span class="gradient-text"
					>Ecosistema Software</span
				>
			</h2>
			<p class="section-description">
				Un ciclo completo de simulación, generación y reconstrucción
				diseñado para optimizar el sistema óptico del ELT.
			</p>
		</div>

		<div class="modules-grid">
			{
				modules.map((mod, index) => (
					<div class="module-card glass" data-index={index}>
						<div class="image-container">
							<img src={mod.image} alt={mod.title} />
							<div
								class="image-overlay"
								style={`background: radial-gradient(circle at center, ${mod.color}33, transparent 70%)`}
							/>
						</div>
						<div class="card-content">
							<h3 class="module-title">{mod.title}</h3>
							<p class="module-subtitle">{mod.subtitle}</p>
							<p class="module-description">{mod.description}</p>
							<ul class="details-list">
								{mod.details.map((detail) => (
									<li>
										<span
											class="bullet"
											style={`background-color: ${mod.color}`}
										/>
										{detail}
									</li>
								))}
							</ul>
						</div>
						{index < modules.length - 1 && (
							<div class="flow-indicator">
								<svg
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
								>
									<path d="M5 12h14M12 5l7 7-7 7" />
								</svg>
							</div>
						)}
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.architecture-section {
		padding: 6rem 1rem;
		position: relative;
		overflow: hidden;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
	}

	.header {
		text-align: center;
		margin-bottom: 5rem;
	}

	.section-title {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
		color: white;
	}

	.section-description {
		color: var(--text-secondary);
		font-size: 1.25rem;
		max-width: 800px;
		margin: 0 auto;
		line-height: 1.6;
	}

	.modules-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2.5rem;
		position: relative;
	}

	.module-card {
		position: relative;
		border-radius: 20px;
		overflow: hidden;
		transition:
			transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
			box-shadow 0.4s;
		display: flex;
		flex-direction: column;
		height: 100%;
		border: 1px solid var(--glass-border);
	}

	.module-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
		border-color: rgba(255, 255, 255, 0.2);
	}

	.image-container {
		height: 220px;
		position: relative;
		overflow: hidden;
	}

	.image-container img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.module-card:hover img {
		transform: scale(1.1);
	}

	.image-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		pointer-events: none;
	}

	.card-content {
		padding: 2.5rem;
		flex-grow: 1;
	}

	.module-title {
		font-size: 1.5rem;
		color: white;
		margin-bottom: 0.5rem;
	}

	.module-subtitle {
		color: var(--accent-cyan);
		font-weight: 600;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 1.5rem;
	}

	.module-description {
		color: var(--text-secondary);
		line-height: 1.6;
		margin-bottom: 2rem;
		font-size: 1rem;
	}

	.details-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.details-list li {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: #e2e8f0;
		font-size: 0.9rem;
		margin-bottom: 0.75rem;
	}

	.bullet {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		flex-shrink: 0;
	}

	.flow-indicator {
		position: absolute;
		right: -1.75rem;
		top: 50%;
		transform: translateY(-50%);
		z-index: 10;
		color: var(--glass-border);
		background: var(--bg-color);
		padding: 0.5rem;
		border: 1px solid var(--glass-border);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.flow-indicator svg {
		width: 20px;
		height: 20px;
	}

	@media (max-width: 768px) {
		.section-title {
			font-size: 2.2rem;
			min-height: 3.5rem;
		}
	}
</style>
