---
const modules = [
	{
		id: "fase",
		title: "1. Simulación de Fase (Zernike)",
		subtitle: "Modelado Matemático de Aberraciones",
		description:
			"Motor central que utiliza la base ortogonal de polinomios de Zernike para descomponer frentes de onda complejos. Permite la síntesis controlada de aberraciones ópticas fundamentales para representar las distorsiones del ELT.",
		details: [
			"Generación de mapas de fase de alta resolución.",
			"Simulación de turbulencia atmosférica residual.",
		],
		image: `${import.meta.env.BASE_URL}images/software/zernike.png`,
		color: "var(--accent-blue)",
	},
	{
		id: "dataset",
		title: "2. Generador de Dataset Visual",
		subtitle: "Propagación Óptica y Síntesis de Imágenes",
		description:
			"Transforma las matrices de fase puras en representaciones visuales realistas mediante propagación de Fraunhofer (FFT). Crea el puente entre la teoría matemática y la observación digital.",
		details: [
			"Cálculo de PSF (Point Spread Function).",
			"Simulación de submuestreo de detectores CMOS/CCD.",
		],
		image: `${import.meta.env.BASE_URL}images/software/generator.png`,
		color: "var(--accent-cyan)",
	},
	{
		id: "cnn",
		title: "3. CNN de Reconstrucción",
		subtitle: "Deep Learning para Inferencia de Fase",
		description:
			"Red Neuronal Convolucional diseñada específicamente para la regresión de coeficientes ópticos. Actúa como el cerebro del sistema, analizando patrones de difracción en tiempo real.",
		details: [
			"Arquitectura optimizada para regresión continua.",
			"Entrenamiento con datasets sintéticos masivos.",
		],
		image: `${import.meta.env.BASE_URL}images/software/cnn.png`,
		color: "#4d7cff",
	},
];
---

<section id="architecture" class="architecture-section">
	<div class="container">
		<div class="header">
			<h2 class="section-title">
				Estructura del <span class="gradient-text"
					>Ecosistema Software</span
				>
			</h2>
		</div>

		<div class="console-unit glass">
			<!-- PANTALLA IZQUIERDA -->
			<div class="monitor-screen">
				<div class="screen-layout active" id="main-screen">
					<div class="screen-visual">
						<div class="image-frame">
							<img
								id="screen-img"
								src={modules[0].image}
								alt={modules[0].title}
							/>
							<div class="scanline"></div>
						</div>
					</div>
					<div class="screen-content">
						<div class="content-header">
							<span id="screen-subtitle" class="accent-label"
								>{modules[0].subtitle}</span
							>
							<h3 id="screen-title" class="title-label">
								{modules[0].title}
							</h3>
						</div>
						<div class="content-body">
							<p id="screen-description">
								{modules[0].description}
							</p>
						</div>
					</div>
				</div>
			</div>

			<!-- PANEL DE CONTROL DERECHO -->
			<div class="control-panel">
				<div class="panel-header">
					<div class="status-indicator">
						<div class="led"></div>
						<span>SISTEMA EN LÍNEA</span>
					</div>
				</div>

				<nav class="selector-list">
					{
						modules.map((mod, index) => (
							<button
								class={`selector-btn ${index === 0 ? "active" : ""}`}
								data-id={mod.id}
								data-title={mod.title}
								data-subtitle={mod.subtitle}
								data-description={mod.description}
								data-image={mod.image}
								data-color={mod.color}
							>
								<div class="selector-visual">
									<div class="selector-thumb">
										<img src={mod.image} alt="" />
									</div>
								</div>
								<div class="selector-info">
									<span class="selector-index">
										MÓDULO 0{index + 1}
									</span>
									<span class="selector-name">
										{mod.title.split(". ")[1]}
									</span>
								</div>
								<div class="selector-led" />
							</button>
						))
					}
				</nav>

				<div class="panel-footer">
					<div class="brand">QUANTIC SOFTWARE ECOSYSTEM</div>
					<div class="version">V 2.0.4</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.architecture-section {
		padding: 3rem 1rem;
		background: radial-gradient(
			circle at center,
			rgba(10, 15, 25, 0.4) 0%,
			transparent 70%
		);
	}

	.container {
		max-width: 1400px;
		margin: 0 auto;
	}

	.header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-title {
		font-size: 3.5rem;
		color: white;
	}

	/* CONSOLA MAESTRA */
	.console-unit {
		display: grid;
		grid-template-columns: 1fr 320px;
		background: rgba(10, 15, 25, 0.6);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 40px;
		overflow: hidden;
		min-height: 500px;
		box-shadow: 0 50px 100px rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(20px);
	}

	/* MONITOR (IZQUIERDA) */
	.monitor-screen {
		padding: 2.5rem;
		position: relative;
		border-right: 1px solid rgba(255, 255, 255, 0.1);
		background: radial-gradient(
			circle at 0% 0%,
			rgba(4, 190, 254, 0.05),
			transparent 60%
		);
	}

	.screen-layout {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 4rem;
		height: 100%;
		opacity: 0;
		transform: scale(0.98);
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.screen-layout.active {
		opacity: 1;
		transform: scale(1);
	}

	.screen-visual {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.image-frame {
		width: 100%;
		max-width: 500px;
		height: 280px;
		border-radius: 20px;
		overflow: hidden;
		border: 2px solid rgba(255, 255, 255, 0.1);
		position: relative;
		background: #000;
	}

	.image-frame img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.8;
	}

	.scanline {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(
			to bottom,
			transparent 50%,
			rgba(4, 190, 254, 0.05) 51%
		);
		background-size: 100% 4px;
		pointer-events: none;
	}

	.screen-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		text-align: left;
	}

	.accent-label {
		color: var(--accent-cyan);
		font-weight: 800;
		font-size: 0.75rem;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		display: block;
		margin-bottom: 1rem;
	}

	.title-label {
		font-size: 2.2rem;
		color: white;
		margin-bottom: 2rem;
		font-family: "Plus Jakarta Sans", sans-serif;
		line-height: 1.2;
	}

	#screen-description {
		color: var(--text-secondary);
		font-size: 1.15rem;
		line-height: 1.8;
		margin-bottom: 0;
	}

	/* PANEL DE CONTROL (DERECHA) */
	.control-panel {
		background: rgba(0, 0, 0, 0.3);
		padding: 2rem;
		display: flex;
		flex-direction: column;
	}

	.panel-header {
		margin-bottom: 3rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}

	.status-indicator {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.65rem;
		color: var(--accent-cyan);
		letter-spacing: 0.1em;
		font-weight: 700;
	}

	.led {
		width: 8px;
		height: 8px;
		background: var(--accent-cyan);
		border-radius: 50%;
		box-shadow: 0 0 10px var(--accent-cyan);
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0% {
			opacity: 1;
		}
		50% {
			opacity: 0.4;
		}
		100% {
			opacity: 1;
		}
	}

	.selector-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		flex-grow: 1;
	}

	.selector-btn {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.05);
		padding: 1rem 1.25rem;
		border-radius: 14px;
		display: flex;
		align-items: center;
		gap: 1.25rem;
		cursor: pointer;
		transition: all 0.3s ease;
		color: white;
		text-align: left;
		width: 100%;
	}

	.selector-btn:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.1);
	}

	.selector-btn.active {
		background: rgba(4, 190, 254, 0.1);
		border: 1px solid var(--accent-cyan);
		box-shadow: inset 0 0 20px rgba(4, 190, 254, 0.05);
	}

	.selector-visual {
		flex-shrink: 0;
	}

	.selector-thumb {
		width: 50px;
		height: 40px;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: #000;
	}

	.selector-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.6;
		transition: opacity 0.3s ease;
	}

	.active .selector-thumb img {
		opacity: 1;
	}

	.active .selector-thumb {
		border-color: var(--accent-cyan);
		box-shadow: 0 0 10px rgba(4, 190, 254, 0.3);
	}

	.selector-info {
		flex-grow: 1;
	}

	.selector-led {
		width: 6px;
		height: 6px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 50%;
	}

	.active .selector-led {
		background: var(--accent-cyan);
		box-shadow: 0 0 10px var(--accent-cyan);
	}

	.panel-footer {
		margin-top: 2rem;
		text-align: center;
		color: rgba(255, 255, 255, 0.1);
		font-size: 0.6rem;
		font-family: monospace;
	}

	/* RESPONSIVO */
	@media (max-width: 1200px) {
		.console-unit {
			grid-template-columns: 1fr;
		}
		.monitor-screen {
			border-right: none;
			border-bottom: 1px solid rgba(255, 255, 255, 0.1);
			padding: 2.5rem;
		}
		.screen-layout {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.image-frame {
			height: 300px;
		}
	}
</style>

<script>
	function initArchitecture() {
		const btns = document.querySelectorAll(".selector-btn");
		const screen = document.getElementById("main-screen");

		const img = document.getElementById("screen-img") as HTMLImageElement;
		const title = document.getElementById("screen-title");
		const subtitle = document.getElementById("screen-subtitle");
		const desc = document.getElementById("screen-description");
		const details = document.getElementById("screen-details");

		btns.forEach((btn) => {
			btn.addEventListener("click", () => {
				if (btn.classList.contains("active")) return;

				// Quitar activos
				btns.forEach((b) => b.classList.remove("active"));
				btn.classList.add("active");

				// Transición pantalla
				if (screen) {
					screen.style.opacity = "0";
					screen.style.transform = "scale(0.98)";

					setTimeout(() => {
						const data = (btn as HTMLElement).dataset;

						if (img) img.src = data.image || "";
						if (title) title.textContent = data.title || "";
						if (subtitle)
							subtitle.textContent = data.subtitle || "";
						if (desc) desc.textContent = data.description || "";

						screen.style.opacity = "1";
						screen.style.transform = "scale(1)";
					}, 300);
				}
			});
		});
	}

	initArchitecture();
	document.addEventListener("astro:page-load", initArchitecture);
</script>
