<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Anteproyecto</title>

		<!-- Google Fonts: Option 1 (Plus Jakarta Sans + Inter) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Noise Texture Overlay -->
		<div class="noise-overlay"></div>

		<!-- Rich Blue Background Glows -->
		<div class="glow-container">
			<div class="glow glow-1"></div>
			<div class="glow glow-2"></div>
			<div class="glow glow-3"></div>
			<div class="glow glow-4"></div>
		</div>

		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #070b13;
		--accent-blue: #3245ff;
		--accent-cyan: #00f2fe;
		--deep-blue: #1e3a8a;
		--text-primary: #ffffff;
		--text-secondary: #94a3b8;
		--glass-bg: rgba(255, 255, 255, 0.03);
		--glass-border: rgba(255, 255, 255, 0.08);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: var(--bg-color);
		color: var(--text-primary);
		font-family: "Inter", sans-serif;
		scroll-behavior: smooth;
		overflow-x: hidden;
	}

	h1,
	h2,
	h3,
	h4,
	.font-heading {
		font-family: "Plus Jakarta Sans", sans-serif;
		letter-spacing: -0.02em;
	}

	/* Noise Texture */
	.noise-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
		opacity: 0.05;
		pointer-events: none;
		z-index: 1000;
		mix-blend-mode: overlay;
	}

	/* Enhanced Background Glows */
	.glow-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}

	.glow {
		position: absolute;
		border-radius: 50%;
		filter: blur(140px);
		opacity: 0.2;
	}

	.glow-1 {
		top: -10%;
		right: -10%;
		width: 60vw;
		height: 60vw;
		background: radial-gradient(circle, var(--accent-blue), transparent);
	}

	.glow-2 {
		bottom: -20%;
		left: -10%;
		width: 80vw;
		height: 80vw;
		background: radial-gradient(circle, var(--accent-cyan), transparent);
		opacity: 0.15;
	}

	.glow-3 {
		top: 30%;
		left: 20%;
		width: 40vw;
		height: 40vw;
		background: radial-gradient(circle, var(--deep-blue), transparent);
		opacity: 0.1;
	}

	.glow-4 {
		bottom: 10%;
		right: 15%;
		width: 50vw;
		height: 50vw;
		background: radial-gradient(circle, #3b82f6, transparent);
		opacity: 0.1;
	}

	.glass {
		background: var(--glass-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--glass-border);
	}

	/* Typing Animation Global Styles */
	.typing-title {
		position: relative;
		display: inline-block;
		min-height: 1.2em;
	}

	.typing-title .cursor {
		display: inline-block;
		width: 0.6em;
		height: 1.1em;
		background: var(--accent-cyan);
		margin-left: 4px;
		animation: blink-global 1s step-end infinite;
		vertical-align: middle;
	}

	@keyframes blink-global {
		from, to { opacity: 1; }
		50% { opacity: 0; }
	}

	.typing-title.finished .cursor {
		display: none;
	}

	.gradient-text {
		background: linear-gradient(135deg, #4481eb 0%, #04befe 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		display: inline;
	}

	.termius-btn {
		display: inline-flex;
		align-items: center;
		padding: 12px 24px;
		background: linear-gradient(135deg, #4481eb 0%, #04befe 100%);
		color: white;
		text-decoration: none;
		border-radius: 30px;
		font-weight: 700;
		font-size: 1rem;
		transition:
			transform 0.2s,
			box-shadow 0.2s;
		box-shadow: 0 4px 15px rgba(4, 190, 254, 0.3);
		font-family: "Plus Jakarta Sans", sans-serif;
	}

	.termius-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(4, 190, 254, 0.4);
	}

	section {
		padding: 80px 20px;
		max-width: 1200px;
		margin: 0 auto;
	}

	@media (max-width: 768px) {
		section {
			padding: 60px 20px;
		}
	}
</style>

<script>
	function initTypingAnimations() {
		const titles = document.querySelectorAll('.typing-title');
		
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const el = entry.target as HTMLElement;
					if (el.dataset.animating !== 'true' && el.dataset.finished !== 'true') {
						startTyping(el);
					}
				}
			});
		}, { threshold: 0.2 });

		titles.forEach(title => {
			const el = title as HTMLElement;
			// Store original HTML and text
			el.dataset.fullHtml = el.innerHTML;
			el.dataset.fullText = el.textContent?.trim() || "";
			
			// Clear and prepare
			el.innerHTML = '<span class="typing-target"></span><span class="cursor">_</span>';
			observer.observe(el);
		});
	}

	function startTyping(el: HTMLElement) {
		el.dataset.animating = 'true';
		const target = el.querySelector('.typing-target');
		const fullText = el.dataset.fullText || "";
		const fullHtml = el.dataset.fullHtml || "";
		let i = 0;

		function type() {
			if (i < fullText.length) {
				if (target) {
					target.textContent += fullText.charAt(i);
				}
				i++;
				
				// Optional: Check if we should restore HTML early to show gradients
				// If the typed text is long enough to include the start of a gradient span
				// we can just swap to full HTML once we're close to the end or have a specific marker.
				
				setTimeout(type, Math.random() * 40 + 30);
			} else {
				// Finish: Restore full HTML to ensure gradients and links work
				el.innerHTML = fullHtml;
				el.classList.add('finished');
				el.dataset.finished = 'true';
				el.dataset.animating = 'false';
			}
		}

		type();
	}

	// Initialize on load
	window.addEventListener('scroll', () => {
		// Just to ensure observer triggers if already in view
	}, { once: true });

	document.addEventListener('DOMContentLoaded', initTypingAnimations);
</script>
