<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link
			rel="icon"
			type="image/svg+xml"
			href={`${import.meta.env.BASE_URL}favicon.svg`}
		/>
		<meta name="generator" content={Astro.generator} />
		<title>Anteproyecto</title>

		<!-- Google Fonts: Option 1 (Plus Jakarta Sans + Inter) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Starfield Canvas -->
		<canvas id="starfield"></canvas>

		<!-- Noise Texture Overlay -->
		<div class="noise-overlay"></div>

		<!-- Rich Blue Background Glows -->
		<div class="glow-container">
			<div class="glow glow-1"></div>
			<div class="glow glow-2"></div>
			<div class="glow glow-3"></div>
			<div class="glow glow-4"></div>
		</div>

		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #070b13;
		--accent-blue: #3245ff;
		--accent-cyan: #00f2fe;
		--deep-blue: #1e3a8a;
		--text-primary: #ffffff;
		--text-secondary: #94a3b8;
		--glass-bg: rgba(255, 255, 255, 0.03);
		--glass-border: rgba(255, 255, 255, 0.08);
	}

	html,
	body {
		margin: 0;
		padding-top: 3rem;
		background-color: var(--bg-color);
		color: var(--text-primary);
		font-family: "Inter", sans-serif;
		scroll-behavior: smooth;
		overflow-x: hidden;
	}

	h1,
	h2,
	h3,
	h4,
	.font-heading {
		font-family: "Plus Jakarta Sans", sans-serif;
		letter-spacing: -0.02em;
	}

	/* Noise Texture */
	.noise-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
		opacity: 0.05;
		pointer-events: none;
		z-index: 5;
		mix-blend-mode: overlay;
	}

	/* Enhanced Background Glows */
	.glow-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}

	#starfield {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
	}

	.glow {
		position: absolute;
		border-radius: 50%;
		filter: blur(140px);
		opacity: 0.2;
		transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.glow-1 {
		top: -10%;
		right: -10%;
		width: 60vw;
		height: 60vw;
		background: radial-gradient(circle, var(--accent-blue), transparent);
	}

	.glow-2 {
		bottom: -20%;
		left: -10%;
		width: 80vw;
		height: 80vw;
		background: radial-gradient(circle, var(--accent-cyan), transparent);
		opacity: 0.15;
	}

	.glow-3 {
		top: 30%;
		left: 20%;
		width: 40vw;
		height: 40vw;
		background: radial-gradient(circle, var(--deep-blue), transparent);
		opacity: 0.1;
	}

	.glow-4 {
		bottom: 10%;
		right: 15%;
		width: 50vw;
		height: 50vw;
		background: radial-gradient(circle, #3b82f6, transparent);
		opacity: 0.1;
	}

	.glass {
		background: var(--glass-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--glass-border);
	}

	/* Typing Animation Global Styles */
	.typing-title {
		position: relative;
		display: inline-block;
		min-height: 1.2em;
		visibility: hidden;
	}

	.typing-title.ready {
		visibility: visible;
	}

	.typing-title .cursor {
		display: inline-block;
		width: 0.6em;
		height: 1.1em;
		background: var(--accent-cyan);
		margin-left: 4px;
		animation: blink-global 1s step-end infinite;
		vertical-align: middle;
	}

	@keyframes blink-global {
		from,
		to {
			opacity: 1;
		}
		50% {
			opacity: 0;
		}
	}

	.typing-title.finished .cursor {
		display: none;
	}

	.gradient-text {
		background: linear-gradient(135deg, #4481eb 0%, #04befe 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		display: inline;
	}

	.termius-btn {
		display: inline-flex;
		align-items: center;
		padding: 12px 24px;
		background: linear-gradient(135deg, #4481eb 0%, #04befe 100%);
		color: white;
		text-decoration: none;
		border-radius: 30px;
		font-weight: 700;
		font-size: 1rem;
		transition:
			transform 0.2s,
			box-shadow 0.2s;
		box-shadow: 0 4px 15px rgba(4, 190, 254, 0.3);
		font-family: "Plus Jakarta Sans", sans-serif;
	}

	.termius-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(4, 190, 254, 0.4);
	}

	section {
		padding: 40px 20px;
		max-width: 1200px;
		margin: 0 auto;
	}

	@media (max-width: 768px) {
		section {
			padding: 30px 20px;
		}
	}
</style>

<script>
	function initTypingAnimations() {
		const titles = document.querySelectorAll(".typing-title");

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const el = entry.target as HTMLElement;
						if (
							el.dataset.animating !== "true" &&
							el.dataset.finished !== "true"
						) {
							startTyping(el);
						}
					}
				});
			},
			{ threshold: 0.2 },
		);

		titles.forEach((title) => {
			const el = title as HTMLElement;

			// Fijar altura para evitar Layout Shift (que el contenido se baje)
			const currentHeight = el.getBoundingClientRect().height;
			el.style.minHeight = `${currentHeight}px`;

			// Store original HTML and text
			el.dataset.fullHtml = el.innerHTML;
			el.dataset.fullText = el.textContent?.trim() || "";

			// Preparar para escritura
			el.innerHTML =
				'<span class="typing-target"></span><span class="cursor">_</span>';

			// Marcar como listo e iniciar observación
			el.classList.add("ready");
			observer.observe(el);
		});
	}

	function startTyping(el: HTMLElement) {
		el.dataset.animating = "true";
		const target = el.querySelector(".typing-target");
		const fullText = el.dataset.fullText || "";
		const fullHtml = el.dataset.fullHtml || "";
		let i = 0;

		function type() {
			if (i < fullText.length) {
				if (target) {
					target.textContent += fullText.charAt(i);
				}
				i++;

				// Optional: Check if we should restore HTML early to show gradients
				// If the typed text is long enough to include the start of a gradient span
				// we can just swap to full HTML once we're close to the end or have a specific marker.

				setTimeout(type, Math.random() * 40 + 30);
			} else {
				// Finish: Restore full HTML to ensure gradients and links work
				el.innerHTML = fullHtml;
				el.classList.add("finished");
				el.dataset.finished = "true";
				el.dataset.animating = "false";
			}
		}

		type();
	}

	// Initialize on load
	window.addEventListener(
		"scroll",
		() => {
			// Just to ensure observer triggers if already in view
		},
		{ once: true },
	);

	document.addEventListener("DOMContentLoaded", initTypingAnimations);
</script>

<script>
	// ─── Starfield ───────────────────────────────────────────────
	const canvas = document.getElementById('starfield') as HTMLCanvasElement;
	const ctx = canvas?.getContext('2d');

	if (canvas && ctx) {
		const c = ctx; // TypeScript pierde el narrowing en funciones anidadas; esta const garantiza que siempre es no-nulo

		function resizeCanvas() {
			canvas.width = window.innerWidth;
			canvas.height = window.innerHeight;
		}
		resizeCanvas();
		window.addEventListener('resize', resizeCanvas);

		type Star = {
			x: number; y: number; r: number;
			baseOpacity: number; opacity: number;
			speed: number; phase: number;
			color: string;
		};

		const STAR_COLORS = [
			'255,255,255',
			'180,210,255',
			'200,230,255',
			'140,190,255',
		];

		const stars: Star[] = [];
		const NUM_STARS = 200;

		for (let i = 0; i < NUM_STARS; i++) {
			stars.push({
				x: Math.random() * canvas.width,
				y: Math.random() * canvas.height,
				r: Math.random() * 1.3 + 0.2,
				baseOpacity: Math.random() * 0.45 + 0.05,
				opacity: 0,
				speed: Math.random() * 0.8 + 0.2,
				phase: Math.random() * Math.PI * 2,
				color: STAR_COLORS[Math.floor(Math.random() * STAR_COLORS.length)],
			});
		}

		let time = 0;
		function animateStars() {
			c.clearRect(0, 0, canvas.width, canvas.height);
			time += 0.012;

			for (const star of stars) {
				const twinkle = Math.sin(time * star.speed + star.phase);
				star.opacity = star.baseOpacity + twinkle * 0.25;
				star.opacity = Math.max(0, Math.min(1, star.opacity));

				// Larger stars get a soft glow
				if (star.r > 1.0) {
					const grd = c.createRadialGradient(
						star.x, star.y, 0,
						star.x, star.y, star.r * 2.5
					);
					grd.addColorStop(0, `rgba(${star.color},${star.opacity})`);
					grd.addColorStop(1, `rgba(${star.color},0)`);
					c.beginPath();
					c.arc(star.x, star.y, star.r * 2.5, 0, Math.PI * 2);
					c.fillStyle = grd;
					c.fill();
				}

				c.beginPath();
				c.arc(star.x, star.y, star.r, 0, Math.PI * 2);
				c.fillStyle = `rgba(${star.color},${star.opacity})`;
				c.fill();
			}

			requestAnimationFrame(animateStars);
		}
		animateStars();
	}

	// ─── Mouse parallax on glows ──────────────────────────────────
	const glow1 = document.querySelector('.glow-1') as HTMLElement | null;
	const glow2 = document.querySelector('.glow-2') as HTMLElement | null;
	const glow3 = document.querySelector('.glow-3') as HTMLElement | null;

	let targetX = 0, targetY = 0;
	let currentX = 0, currentY = 0;

	document.addEventListener('mousemove', (e) => {
		targetX = (e.clientX / window.innerWidth - 0.5) * 2;
		targetY = (e.clientY / window.innerHeight - 0.5) * 2;
	});

	function animateGlows() {
		currentX += (targetX - currentX) * 0.04;
		currentY += (targetY - currentY) * 0.04;

		if (glow1) glow1.style.transform = `translate(${currentX * 40}px, ${currentY * 30}px)`;
		if (glow2) glow2.style.transform = `translate(${currentX * -25}px, ${currentY * -20}px)`;
		if (glow3) glow3.style.transform = `translate(${currentX * 15}px, ${currentY * 10}px)`;

		requestAnimationFrame(animateGlows);
	}
	animateGlows();
</script>
